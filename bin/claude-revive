#!/usr/bin/env bash
# claude-revive — auto-respawning Claude Code wrapper.
#
# Starts fresh OR resumes, depending on whether a prior conversation exists
# for the current directory (detected via ~/.claude/projects/<encoded-cwd>).
# This matters when a tmux window is freshly spawned for a project that
# already has a Claude history on disk — we want --continue from the very
# first launch, not from the second.
#
# On any exit, respawns with --continue so in-conversation history is
# preserved. Press Ctrl+C during the 5s grace window to stop the loop.
#
# Remote-Control relay drops (where claude stays alive but the cloud
# websocket dies) are handled by the separate `claude-rc-watchdog`,
# which polls panes externally and SIGTERMs claude when the footer's
# "Remote Control active" indicator goes missing — triggering this
# script's restart loop, which re-registers via --continue.

set -u

FLAGS=(--dangerously-skip-permissions --remote-control)

# Claude encodes project dirs by replacing /, ., and _ with - (so
# /Volumes/SAMSUNG_SSD_990_PRO/.foo becomes -Volumes-SAMSUNG-SSD-990-PRO--foo
# under ~/.claude/projects). Resolve symlinks first (pwd -P) so a window
# launched via a symlinked path still finds the real transcript directory.
encoded_cwd="$(pwd -P | sed 's|[/._]|-|g')"
project_dir="$HOME/.claude/projects/$encoded_cwd"

# Persistent respawn log. Every wrapper-level event (start, claude exit,
# restart, Ctrl+C) is appended here in addition to being printed to the
# pane, so post-mortem visibility survives tmux scrollback overflow and
# tmux server restarts. One file per project keeps grep targeted.
LOG_DIR="$HOME/.claude-orchestrator/logs"
LOG_FILE="$LOG_DIR/revive-$encoded_cwd.log"
mkdir -p "$LOG_DIR" 2>/dev/null

revive_log() {
  printf '[claude-revive] %s\n' "$*"
  printf '[%s] [claude-revive] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >> "$LOG_FILE" 2>/dev/null
}

shopt -s nullglob
jsonls=("$project_dir"/*.jsonl)
shopt -u nullglob

if [[ ${#jsonls[@]} -gt 0 ]]; then
  revive_log "Found prior history for $(pwd) — resuming with --continue."
  first=0
else
  revive_log "No prior history for $(pwd) — starting fresh."
  first=1
fi

trap 'echo ""; revive_log "Loop stopped."; exit 0' INT TERM

while true; do
  if [[ "$first" -eq 1 ]]; then
    claude "${FLAGS[@]}"
    first=0
  else
    claude "${FLAGS[@]}" --continue
  fi
  status=$?

  echo ""
  revive_log "Claude exited (status $status)."
  revive_log "Restarting in 5s. Ctrl+C to stop the loop."
  sleep 5 || break
done
